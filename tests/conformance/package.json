{
  "name": "@fast-react/conformance",
  "version": "0.0.0",
  "private": true,
  "description": "Deterministic runtime/package inventory generation for pinned React targets.",
  "type": "module",
  "scripts": {
    "inventory:generate": "node scripts/generate-runtime-inventory.mjs --write",
    "inventory:print": "node scripts/print-inventory.mjs --format=json",
    "inventory:print:markdown": "node scripts/print-inventory.mjs --format=markdown",
    "check": "npm test",
    "test": "node --test test/*.test.mjs"
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
