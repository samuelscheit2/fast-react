{
  "name": "fast-react-workspace",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "fast-react-workspace",
      "version": "0.0.0",
      "license": "UNLICENSED",
      "workspaces": [
        "packages/*",
        "bindings/*",
        "tests/*"
      ],
      "engines": {
        "node": ">=26.0.0",
        "npm": ">=11.0.0"
      }
    },
    "bindings/node": {
      "name": "@fast-react/native",
      "version": "0.0.0",
      "engines": {
        "node": ">=22.0.0"
      }
    },
    "node_modules/@fast-react/conformance": {
      "resolved": "tests/conformance",
      "link": true
    },
    "node_modules/@fast-react/native": {
      "resolved": "bindings/node",
      "link": true
    },
    "node_modules/@fast-react/react": {
      "resolved": "packages/react",
      "link": true
    },
    "node_modules/@fast-react/react-dom": {
      "resolved": "packages/react-dom",
      "link": true
    },
    "node_modules/@fast-react/react-test-renderer": {
      "resolved": "packages/react-test-renderer",
      "link": true
    },
    "node_modules/scheduler": {
      "resolved": "packages/scheduler",
      "link": true
    },
    "packages/react": {
      "name": "@fast-react/react",
      "version": "0.0.0",
      "engines": {
        "node": ">=26.0.0"
      }
    },
    "packages/react-dom": {
      "name": "@fast-react/react-dom",
      "version": "0.0.0",
      "dependencies": {
        "scheduler": "^0.27.0"
      },
      "engines": {
        "node": ">=26.0.0"
      },
      "peerDependencies": {
        "@fast-react/react": "0.0.0"
      }
    },
    "packages/react-test-renderer": {
      "name": "@fast-react/react-test-renderer",
      "version": "0.0.0",
      "dependencies": {
        "scheduler": "^0.27.0"
      },
      "engines": {
        "node": ">=26.0.0"
      },
      "peerDependencies": {
        "@fast-react/react": "0.0.0"
      }
    },
    "packages/scheduler": {
      "version": "0.27.0",
      "license": "MIT",
      "engines": {
        "node": ">=26.0.0"
      }
    },
    "tests/conformance": {
      "name": "@fast-react/conformance",
      "version": "0.0.0",
      "engines": {
        "node": ">=26.0.0"
      }
    }
  }
}
