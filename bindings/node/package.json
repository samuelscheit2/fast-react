{
  "name": "@fast-react/native",
  "version": "0.0.0",
  "private": true,
  "description": "Node loader placeholder for the Fast React native binding.",
  "type": "module",
  "main": "./index.cjs",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "cargo build -p fast-react-napi",
    "check": "node -e \"require('./index.cjs')\"",
    "test": "node -e \"const native = require('./index.cjs'); if (native.bindingStatus !== 'placeholder') process.exit(1)\""
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
